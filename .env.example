# Firebase configuration (Vite exposes only VITE_* to the client)
# Copy this file to .env.local and fill in real values from Firebase Console.
# Do not commit .env.local.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=threedribblesnew.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=threedribblesnew
VITE_FIREBASE_STORAGE_BUCKET=threedribblesnew.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_URL=
